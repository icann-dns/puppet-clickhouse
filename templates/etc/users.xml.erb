<%-
  def parse_value(value)
    case value
    when TrueClass, FalseClass
      value ? '1' : '0'
    else
      value
    end
  end
-%>
<?xml version="1.0"?>
<yandex>
<%- unless @profiles.empty? -%>
  <profiles>
  <%- @profiles.each_pair do |profile, config| -%>
    <%= "<#{profile}>" %>
    <%- config.each_pair do |key, value| -%>
      <<%= key %>><%= parse_value(value) %></<%= key %>>
    <%- end -%>
    <%= "</#{profile}>" %>
  <%- end -%>
  </profiles>
<%- end -%>
<%- unless @roles.empty? -%>
  <roles>
  <%- @roles.each_pair do |role, grants| -%>
  <%= "<#{role}>" %>
    <grants>
    <%- grants.each do |grant| -%>
      <grant>
        <query><%= grant %></query>
      </grant>
    <%- end -%>
    </grants>
  <%= "</#{role}>" %>
  <%- end -%>
  </roles>
<%- end -%>
  <users>
     <default>
<%- if @default_password_sha256 -%>
          <password_sha256_hex><%= @default_password_sha256 %></password_sha256_hex>
<%- else -%>
          <password><%= @default_password %></password>
<%- end -%>
          <networks>
<%- @default_networks.each do |network| -%>
            <ip><%= network %></ip>
<%- end -%>
          </networks>
          <profile><%= @default_profile %></profile>
          <quota><%= @default_quota %></quota>
<%- if @default_allow_databases -%>
          <allow_databases>
  <%- @default_allow_databases.each do |database| -%>
            <database><%= database %></database>
  <%- end -%>
          </allow_databases>
<%- end -%>
<%- if @default_filter -%>
          <databases>
  <%- @default_filter.each_pair do |database, databasefilter| -%>
            <<%= database %>>
    <%- databasefilter.each do |filter| -%>
              <<%= filter['table'] %>>
                <filter><%= filter['tablefilter'] %></filter>
              </<%= filter['table'] %>>
    <%- end -%>
            </<%= database %>>
  <%- end -%>
          </databases>
<%- end -%>
    </default>
<%- @users.each_pair do |user, config| -%>
    <%= "<#{user}>" %>
      <password><%= config.fetch('password', '') %></password>
      <networks>
  <%- config['networks'].each do |network| -%>
        <ip><%= network %></ip>
  <%- end -%>
      </networks>
  <%- if config['access_management'] -%>
      <access_management>1</access_management>
  <%- end -%>
      <profile><%= config.fetch('profile', 'default') %></profile>
      <quota><%= config.fetch('quota', 'default') %></quota>
  <%- if config['roles'] -%>
      <grants>
    <%- config['roles'].each do |role| -%>
        <query>GRANT <%= role %></query>
    <%- end -%>
      </grants>
  <%- end -%>
  <%- if config['allow_db'] -%>
      <allow_databases>
      <%- config['allow_db'].each do |db| -%>
        <database><%= db %></database>
      <%- end -%>
      </allow_databases>
<%- end -%>
    <%= "</#{user}>" %>
<%- end -%>
  </users>
<%- unless @quotas.empty? -%>
  <quotas>
  <%- @quotas.each_pair do |quota, config| -%>
    <%= "<#{quota}>" %>
    <%- if config.fetch('keyed', nil) == 'client_key' -%>
      <keyed />
    <%- elsif config.fetch('keyed', nil) == 'ip_address' -%>
      <keyed_by_ip />
    <%- end -%>
    <%- config['intervals'].each do |interval| -%>
      <interval>
      <%- interval.each_pair do |key, value| -%>
        <<%= key %>><%= parse_value(value) %></<%= key %>>
      <%- end -%>
      </interval>
    <%- end -%>
    <%= "</#{quota}>" %>
  <%- end -%>
  </quotas>
<%- end -%>
</yandex>
